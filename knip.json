{
  "entry": ["test/**/*.ts"],
  "project": ["src/**/*.ts", "test/**/*.ts"],
  "ignoreExportsUsedInFile": true,
  "rules": {
    "files": "error",
    "dependencies": "error",
    "unlisted": "error",
    "exports": "error",
    "types": "error",
    "enumMembers": "error",
    "classMembers": "error",
    "duplicates": "error"
  }
}
