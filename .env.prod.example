# Runtime
NODE_ENV=production
APP_VERSION=0.1.0
PORT=3002

# Telegram
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=your_production_telegram_bot_token

# Database (existing PostgreSQL on VPS, separate schema/user for swapper-bot)
DATABASE_URL=postgresql://swapper_bot_app:change_me@127.0.0.1:5432/whale_alert_bot?options=-csearch_path%3Dswapper_bot%2Cpublic

# Aggregators
ZERO_X_API_KEY=your_0x_api_key
ZERO_X_API_BASE_URL=https://api.0x.org
ZERO_X_TAKER_ADDRESS=0x0000000000000000000000000000000000010000
ZEROX_FEE_RECIPIENT=
ZEROX_FEE_BPS=0
ZEROX_FEE_TOKEN_MODE=buy
PARASWAP_API_BASE_URL=https://api.paraswap.io
PARASWAP_API_VERSION=6.2
PARASWAP_PARTNER_ADDRESS=
PARASWAP_PARTNER_NAME=
PARASWAP_FEE_BPS=0
ODOS_API_BASE_URL=https://api.odos.xyz
ODOS_API_KEY=your_odos_api_key
ODOS_MONETIZATION_MODE=disabled
JUPITER_API_BASE_URL=https://lite-api.jup.ag
JUPITER_API_KEY=
JUPITER_PLATFORM_FEE_BPS=0
JUPITER_FEE_ACCOUNT_SOL=
JUPITER_FEE_ACCOUNT_USDC=
JUPITER_FEE_ACCOUNT_USDT=
JUPITER_FEE_ACCOUNT_JUP=
JUPITER_FEE_ACCOUNT_BONK=

# WalletConnect
WC_PROJECT_ID=your_walletconnect_project_id
APP_PUBLIC_URL=https://1303118-cr22992.tw1.ru
SWAP_SLIPPAGE=0.5
SWAP_TIMEOUT_SECONDS=300

# Chain/infra
ETH_RPC_URL=
ARBITRUM_RPC_URL=
BASE_RPC_URL=
OPTIMISM_RPC_URL=
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
EXPLORER_URL_ETHEREUM=https://etherscan.io/tx/
EXPLORER_URL_ARBITRUM=https://arbiscan.io/tx/
EXPLORER_URL_BASE=https://basescan.org/tx/
EXPLORER_URL_OPTIMISM=https://optimistic.etherscan.io/tx/
EXPLORER_URL_SOLANA=https://solscan.io/tx/
CACHE_TTL_PRICE=30
METRICS_ENABLED=true
